<UserControl x:Class="WinApp.Views.AlarmStation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <vst:GridLayout BorderThickness="1" 
                    BorderBrush="LightGray"
                    CornerRadius="6" 
                    Margin="10 10 10 0"
                    Background="White"
                    Padding="0 20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25*" />
                <ColumnDefinition Width="75*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Viewbox Width="60" Height="60" x:Name="Indicator">
            </Viewbox>
            <TextBlock Text="{Binding Path=Time, StringFormat=HH:mm}" 
                       Grid.Row="1"
                       FontSize="16"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center" />

            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Path=ObjectId}" Foreground="Gray" />
                <vst:HeaderText HeaderSize="5" Text="{Binding Path=Name}" />
            </StackPanel>
            <TextBlock FontSize="16" 
                       Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding Path=Address}" Margin="0 10 0 0" Foreground="Gray" />
        </Grid>
    </vst:GridLayout>
</UserControl>
