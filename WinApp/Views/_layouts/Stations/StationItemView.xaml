<UserControl x:Class="WinApp.Views.StationItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             MinWidth="200"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="vst:GridLayout">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource GrayBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <vst:GridLayout BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="10">

        <StackPanel>
            <TextBlock Text="{Binding Path=ObjectId}" Foreground="Gray" />
            <TextBlock FontSize="16" Text="{Binding Path=Name}" />
            <TextBlock FontSize="12" Text="{Binding Path=Address}" Margin="0 10 0 0" Foreground="Gray" />
        </StackPanel>
    </vst:GridLayout>
</UserControl>
