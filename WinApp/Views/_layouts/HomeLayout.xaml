<UserControl x:Class="WinApp.Views.HomeLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="5" />
            <ColumnDefinition x:Name="FlyoutColumn" Width="0" Tag="400" />
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" />

        <local:HomeStationList x:Name="StationsContent" />

        <vst:MyScrollViewer Grid.Column="2" 
                x:Name="DetailContent"
                Background="White">
            <local:AlarmStationList x:Name="alarmsContent" />
        </vst:MyScrollViewer>
    </Grid>
</UserControl>
