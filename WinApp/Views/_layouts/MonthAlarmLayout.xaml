<UserControl x:Class="WinApp.Views.MonthAlarmLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="flyingColumn" 
                              Tag="500"
                              Width="0" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1">
            <Border Background="{StaticResource BannerBrush}" Opacity="0.9" />
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <local:CalendarView />
            </Grid>

            <vst:CloseButon Foreground="Black"
                                x:Name="ButtonCloseCalendar"
                                Background="{StaticResource BannerBrush}"
                                Width="20" VerticalAlignment="Top" Margin="20" />
        </Grid>
    </Grid>
</UserControl>
