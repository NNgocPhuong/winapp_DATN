<UserControl x:Class="WinApp.Views.MonitoringLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinApp.Views"
             xmlns:vst="clr-namespace:Vst.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="8" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      />
            <Border x:Name="LeftPanel">
                <local:CurrentStationView x:Name="StationView" />
            </Border>

            <Border Grid.Column="2" x:Name="RightPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="8" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <GridSplitter Grid.Row="1" 
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                               />

                    <vst:MyScrollViewer x:Name="TopPanel">
                        <local:HistoryListView x:Name="LastAlarmList" />
                    </vst:MyScrollViewer>
                    <vst:MyScrollViewer x:Name="BottomPanel" Grid.Row="2">
                        <local:MonthHistoryListView x:Name="SummaryList" />
                    </vst:MyScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="flyingColumn" 
                              Tag="400"
                              Width="0" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Border Background="{StaticResource BannerBrush}" Opacity="0.9" />
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <local:CalendarView x:Name="Calendar" />

                    <vst:MyScrollViewer Grid.Row="2" Background="White">
                        <local:HistoryListView x:Name="DayAlarmList" />
                    </vst:MyScrollViewer>
                </Grid>

                <vst:CloseButon Foreground="Black"
                                x:Name="ButtonCloseCalendar"
                                Background="{StaticResource BannerBrush}"
                                Width="20" VerticalAlignment="Top" Margin="20" />
            </Grid>
        </Grid>

    </Grid>
</UserControl>
