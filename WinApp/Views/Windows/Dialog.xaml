<Window x:Class="WinApp.Views.Dialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinApp.Views"
        xmlns:vst="clr-namespace:Vst.Controls"
        mc:Ignorable="d"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Title="Dialog">
    <Border Background="White" 
            BorderThickness="1"
            CornerRadius="6"
            BorderBrush="Gray">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <Grid Margin="20,0">
                <vst:HeaderText HeaderSize="4" Text="{Binding Path=Caption}" />
                <vst:CloseButon HorizontalAlignment="Right"
                                Padding="5"
                                Foreground="Gray" 
                                Background="White" 
                                x:Name="ButtonX" />

                <Border Height="1" Background="WhiteSmoke" VerticalAlignment="Bottom" />
            </Grid>
            <Border x:Name="Body" Grid.Row="1" 
                    MinWidth="450"
                    MinHeight="100">
                
            </Border>
            <Grid Grid.Row="2" Background="WhiteSmoke">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                </Grid>
                <vst:HeaderText HeaderSize="7" x:Name="Comment" VerticalAlignment="Center" Margin="10">
                    
                </vst:HeaderText>
                <StackPanel Orientation="Horizontal"
                            Margin="20,0"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <vst:Button Padding="20,10" 
                                Width="80" 
                                x:Name="ButtonAccept" 
                                Text="OK" 
                                BorderRadius="4" />
                    <vst:Button Padding="20,10" 
                                Width="80" 
                                x:Name="ButtonCancel" 
                                Text="Cancel" 
                                BorderRadius="4"
                                Background="Black" />
                </StackPanel>

                <Grid Grid.ColumnSpan="2" x:Name="Fade" Visibility="Hidden">
                    <local:WaitingIndicator HorizontalAlignment="Left" Width="30" Height="30" Margin="20 0" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
